---
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';

const { posts } = Astro.props;
---

<ul>
  {
  posts.map((post) => (
  <li>
    <a href={`/blog/${post.id}/`}>
      <h4 class="title">{post.data.title}</h4>
      <p class="date">
      <FormattedDate date={post.data.pubDate} />
      </p>
    </a>
  </li>
  ))
  }
</ul>
<style>
  main {
    width: 960px;
  }
  ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  ul li {
    width: calc(50% - 1rem);
  }
  ul li a {
    padding: 1em;
    border-radius: 12px;
    border: 1px solid rgb(var(--gray-light));
  }
  ul li * {
    text-decoration: none;
    transition: 0.2s ease;
  }
  ul li .thumbnail {
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 2/1;
    border-radius: 12px;
    height: auto;
    font-size: 1.3em;
    background: linear-gradient(270deg,rgba(66, 66, 66, 1) 0%, rgba(8, 8, 8, 1) 100%);
    color: white;
    margin-bottom: 0.5rem;
  }
  ul li a {
    display: block;
  }
  .title {
    margin: 0;
    color: rgb(var(--black));
    line-height: 1;
  }
  .date {
    margin: 0;
    color: rgb(var(--gray));
  }

  ul li a:hover {
    border-color: rgb(var(--gray));
  }

  ul li a:hover h4,
  ul li a:hover .date {
    color: rgb(var(--gray));
    transition: color 1s ease;
  }

  @media (max-width: 720px) {
    ul {
      gap: 0.5em;
    }
    ul li {
      width: 100%;
      text-align: center;
    }
    ul li:first-child {
      margin-bottom: 0;
    }
    ul li:first-child .title {
      font-size: 1.563em;
    }
  }
</style>
